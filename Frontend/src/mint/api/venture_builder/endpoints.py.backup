            status=status,
            vb_id=str(vb_id) if vb_id else None,
            start_date=start_date,
            end_date=end_date,
            page=page,
            page_size=page_size,
        )
        # Convert disputes to response models
        result["disputes"] = [DisputeWithDetailsResponse(**d) for d in result["disputes"]]
        return result
    except VBBaseException as e:
        handle_vb_exception(e)


