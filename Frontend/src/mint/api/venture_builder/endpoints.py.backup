# =====================================================
# AVAILABILITY PROFILE ENDPOINTS
# =====================================================


@router.put("/{vb_id}/availability-profile", response_model=List[AvailabilityProfileResponse])
async def upsert_availability_profile(
    vb_id: UUID,
    data: AvailabilityProfileUpsert,
    current_user: dict = Depends(get_vb_or_admin_user),
):
    """
    VB only: Set availability profile (working hours).

    Replaces all existing availability settings for the VB.
    Each day_of_week (0=Sunday to 6=Saturday) can have one entry.
    """
    try:
        # Verify VB owns this profile or is admin
        vb_profile = vb_service.get_vb_by_user_id(current_user["user_id"])
        user_role = current_user.get("roles", [])[0] if current_user.get("roles") else None

        if not vb_profile or str(vb_profile["id"]) != str(vb_id):
            if user_role not in ["admin", "super_admin"]:
                raise VBAccessDeniedError("Can only modify your own availability")

        profiles = vb_service.upsert_availability_profiles(str(vb_id), data.profiles)
        return [AvailabilityProfileResponse(**p) for p in profiles]
    except VBBaseException as e:
        handle_vb_exception(e)


@router.get("/{vb_id}/availability-profile", response_model=List[AvailabilityProfileResponse])
async def get_availability_profile(vb_id: UUID):
    """
    Public: Get availability profile (working hours) for a VB.
    """
    try:
        profiles = vb_service.get_availability_profiles(str(vb_id))
        return [AvailabilityProfileResponse(**p) for p in profiles]
    except VBBaseException as e:
        handle_vb_exception(e)


@router.delete("/{vb_id}/availability-profile/{day_of_week}")
async def delete_availability_day(
    vb_id: UUID,
    day_of_week: int = Path(..., ge=0, le=6, description="0=Sunday, 6=Saturday"),
    current_user: dict = Depends(get_vb_or_admin_user),
):
    """
    VB only: Remove availability for a specific day.
    """
    try:
        vb_profile = vb_service.get_vb_by_user_id(current_user["user_id"])
        user_role = current_user.get("roles", [])[0] if current_user.get("roles") else None

        if not vb_profile or str(vb_profile["id"]) != str(vb_id):
            if user_role not in ["admin", "super_admin"]:
                raise VBAccessDeniedError("Can only modify your own availability")

        vb_service.delete_availability_day(str(vb_id), day_of_week)
        return {"status": "success", "message": f"Removed availability for day {day_of_week}"}
    except VBBaseException as e:
        handle_vb_exception(e)


# =====================================================
# PUBLIC AVAILABILITY ENDPOINT
# =====================================================


@router.get("/{vb_id}/availability", response_model=AvailabilityResponse)
async def get_available_slots(
    vb_id: UUID,
    start_date: str = Query(..., description="Start date (ISO format: YYYY-MM-DD)"),
    end_date: str = Query(..., description="End date (ISO format: YYYY-MM-DD)"),
    current_user: dict = Depends(get_current_user),
):
    """
    Public: Get available booking slots for a VB.

    Computes availability by combining:
    - VB's configured working hours
    - Existing Yuba bookings
    - Google Calendar busy times (if connected)
    - Buffers and session limits

    Returns a list of available time slots within the date range.
    """
    try:
        # Parse date strings to datetime objects
        from datetime import datetime
        from zoneinfo import ZoneInfo

        start_dt = datetime.strptime(start_date, "%Y-%m-%d").replace(tzinfo=ZoneInfo("UTC"))
        end_dt = datetime.strptime(end_date, "%Y-%m-%d").replace(
            hour=23, minute=59, second=59, tzinfo=ZoneInfo("UTC")
        )

        # Get VB's timezone from calendar connection
        calendar_status = vb_service.get_calendar_status(str(vb_id))
        vb_timezone = calendar_status.get("time_zone", "UTC")

        slots = vb_service.get_available_slots(
            vb_id=str(vb_id),
            start_date=start_dt,
            end_date=end_dt,
        )
        return AvailabilityResponse(
            vb_id=vb_id,
            time_zone=vb_timezone,
            slots=[TimeSlot(start=s["start"], end=s["end"], available=s["available"]) for s in slots],
            date_range={"start_date": start_date, "end_date": end_date},
        )
    except VBBaseException as e:
        handle_vb_exception(e)


# =====================================================
# SESSION MANAGEMENT
# =====================================================


@router.post("/sessions/{session_id}/complete")
async def complete_session(
    session_id: UUID,
    current_user: dict = Depends(get_vb_or_admin_user),
):
    """
    VB or Admin: Mark a session as completed.

    Can only be done after the session has ended (or within 10 minutes of ending).
    Only the VB who owns the session or an admin can complete it.
    """
    try:
        user_role = current_user.get("roles", [])[0] if current_user.get("roles") else None
        is_admin = user_role in ["admin", "super_admin"]

        result = vb_service.complete_session(
            session_id=str(session_id),
            completed_by_user_id=current_user["user_id"],
            is_admin=is_admin,
        )
        return result
    except VBBaseException as e:
        handle_vb_exception(e)


@router.delete("/sessions/{session_id}")
async def cancel_session(
    session_id: UUID,
    current_user: dict = Depends(get_current_user),
):
    """
    User, VB, or Admin: Cancel a booked session.

    Can only be cancelled before the session start time.
    Deletes the associated Google Calendar event if one exists.
    Refunds credits to the tenant by restoring them to original credit lots.
    """
    try:
        user_role = current_user.get("roles", [])[0] if current_user.get("roles") else None
        is_admin = user_role in ["admin", "super_admin"]

        result = vb_service.cancel_session(
            session_id=str(session_id),
            requesting_user_id=current_user["user_id"],
            is_admin=is_admin,
        )
        return result
    except VBBaseException as e:
        handle_vb_exception(e)
