@router.patch("/admin/vb/{vb_id}/publish", response_model=VBProfileResponse)
async def publish_unpublish_vb(
    vb_id: UUID,
    data: VBPublishRequest,
    current_user: dict = Depends(get_admin_user),
):
    """
    Admin only: Publish or unpublish a VB.

    Toggles between 'active' and 'inactive' status.
    """
    try:
        if data.is_active:
            profile = vb_service.activate_vb(str(vb_id))
        else:
            profile = vb_service.deactivate_vb(str(vb_id))
        return VBProfileResponse(**profile)
    except VBBaseException as e:
        handle_vb_exception(e)


