{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "amrg_a4_schema",
  "title": "AMRG PRD Schema - A4 Tech-Enabled Service",
  "description": "Schema for Tech-Enabled Service MVP PRD (Software + Operations)",
  "allOf": [
    {"$ref": "base_schema.json"}
  ],
  "properties": {
    "template_code": {
      "const": "A4"
    },
    "service_software_split": {
      "type": "object",
      "required": ["software_components", "human_operations"],
      "properties": {
        "software_components": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "component_name": {"type": "string"},
              "function": {"type": "string"},
              "automation_level": {"type": "string"}
            }
          }
        },
        "human_operations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "operation_name": {"type": "string"},
              "role_responsible": {"type": "string"},
              "why_manual": {"type": "string"}
            }
          }
        },
        "handoff_points": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "end_to_end_journey": {
      "type": "object",
      "required": ["journey_steps"],
      "properties": {
        "journey_steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step_name": {"type": "string"},
              "channel": {"type": "string"},
              "owner": {"type": "string", "enum": ["software", "human", "hybrid"]}
            }
          },
          "minItems": 3
        },
        "total_turnaround_target": {"type": "string"},
        "touchpoints": {"type": "array", "items": {"type": "string"}}
      }
    },
    "operational_data_flows": {
      "type": "object",
      "properties": {
        "data_captured": {"type": "array", "items": {"type": "string"}},
        "data_shared_with_ops": {"type": "array", "items": {"type": "string"}},
        "tracking_dashboards": {"type": "array", "items": {"type": "string"}}
      }
    },
    "capacity_service_levels": {
      "type": "object",
      "properties": {
        "initial_capacity": {"type": "string"},
        "scaling_approach": {"type": "string"},
        "service_level_targets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "metric": {"type": "string"},
              "target": {"type": "string"}
            }
          }
        }
      }
    },
    "quality_management": {
      "type": "object",
      "properties": {
        "quality_checks": {"type": "array", "items": {"type": "string"}},
        "feedback_collection": {"type": "string"},
        "improvement_process": {"type": "string"}
      }
    }
  },
  "required": ["service_software_split", "end_to_end_journey"]
}
