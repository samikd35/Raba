{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "amrg_a1_schema",
  "title": "AMRG PRD Schema - A1 Software/SaaS",
  "description": "Schema for Software/SaaS MVP PRD (web or mobile apps)",
  "allOf": [
    {"$ref": "base_schema.json"}
  ],
  "properties": {
    "template_code": {
      "const": "A1"
    },
    "data_requirements": {
      "type": "object",
      "required": ["user_inputs", "system_outputs"],
      "properties": {
        "user_inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field_name", "purpose"],
            "properties": {
              "field_name": {"type": "string"},
              "field_type": {"type": "string"},
              "purpose": {"type": "string"},
              "is_required": {"type": "boolean"}
            }
          },
          "minItems": 1
        },
        "system_outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["output_name", "description"],
            "properties": {
              "output_name": {"type": "string"},
              "output_type": {"type": "string", "enum": ["dashboard", "report", "alert", "notification", "export", "message", "sms", "email", "document", "receipt", "certificate", "invoice", "confirmation", "response", "file", "api_response", "physical_delivery", "service_completion", "shipping_label", "product_package", "batch_record", "sensor_data", "control_signal", "firmware_update"]},
              "description": {"type": "string"}
            }
          }
        }
      }
    },
    "automation_level": {
      "type": "object",
      "required": ["manual_processes", "automated_processes"],
      "properties": {
        "manual_processes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "process_name": {"type": "string"},
              "reason_for_manual": {"type": "string"}
            }
          }
        },
        "automated_processes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "process_name": {"type": "string"},
              "automation_type": {"type": "string"},
              "fallback_if_fails": {"type": "string"}
            }
          }
        },
        "ai_features": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "feature_name": {"type": "string"},
              "ai_capability": {"type": "string"},
              "fallback": {"type": "string"}
            }
          }
        }
      }
    },
    "platform_choices": {
      "type": "object",
      "required": ["primary_platform", "access_method"],
      "properties": {
        "primary_platform": {
          "type": "string",
          "enum": ["web", "mobile", "both", "desktop", "sms", "ussd", "voice", "whatsapp", "telegram", "api", "pos", "kiosk", "embedded", "in_person", "phone", "field_service", "retail", "wholesale", "direct_sales", "ecommerce", "marketplace", "distributor", "firmware", "companion_app", "cloud_dashboard"]
        },
        "platform_rationale": {"type": "string"},
        "access_method": {
          "type": "string",
          "enum": ["login", "link", "access_code", "public", "sms_shortcode", "ussd_code", "phone_call", "qr_code", "api_key", "oauth", "biometric", "pin", "no_auth", "walk_in", "appointment", "referral", "retail_purchase", "wholesale_order", "direct_order", "subscription", "bluetooth_pairing", "wifi_setup", "physical_button", "nfc"]
        },
        "mobile_considerations": {"type": "string"}
      }
    }
  },
  "required": ["data_requirements", "automation_level", "platform_choices"]
}
