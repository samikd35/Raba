{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "amrg_c1_schema",
  "title": "AMRG PRD Schema - C1 Physical Consumer Product (CPG/FMCG)",
  "description": "Schema for Physical Consumer Product MVP PRD",
  "allOf": [
    {"$ref": "base_schema.json"}
  ],
  "properties": {
    "template_code": {
      "const": "C1"
    },
    "consumer_use_case": {
      "type": "object",
      "required": ["product_category", "consumption_context"],
      "properties": {
        "product_category": {"type": "string"},
        "consumption_context": {"type": "string"},
        "usage_frequency": {"type": "string"},
        "purchase_occasion": {"type": "string"},
        "competing_alternatives": {"type": "array", "items": {"type": "string"}}
      }
    },
    "product_composition": {
      "type": "object",
      "properties": {
        "key_ingredients": {"type": "array", "items": {"type": "string"}},
        "formulation_approach": {"type": "string"},
        "quality_attributes": {"type": "array", "items": {"type": "string"}},
        "shelf_life": {"type": "string"}
      }
    },
    "packaging_formats": {
      "type": "object",
      "properties": {
        "primary_packaging": {
          "type": "object",
          "properties": {
            "format": {"type": "string"},
            "size": {"type": "string"},
            "material": {"type": "string"}
          }
        },
        "sku_variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "variant_name": {"type": "string"},
              "size": {"type": "string"},
              "target_price": {"type": "string"}
            }
          }
        },
        "labeling_requirements": {"type": "array", "items": {"type": "string"}}
      }
    },
    "production_qc": {
      "type": "object",
      "properties": {
        "manufacturing_approach": {"type": "string", "enum": ["in_house", "contract_manufacturing", "hybrid"]},
        "production_partner": {"type": "string"},
        "quality_controls": {"type": "array", "items": {"type": "string"}},
        "batch_size_initial": {"type": "string"},
        "lead_time": {"type": "string"}
      }
    },
    "distribution_channels": {
      "type": "object",
      "properties": {
        "primary_channels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "channel_name": {"type": "string"},
              "channel_type": {"type": "string", "enum": ["retail", "wholesale", "direct", "online", "agent"]},
              "geographic_coverage": {"type": "string"}
            }
          }
        },
        "route_to_market": {"type": "string"},
        "distribution_partners": {"type": "array", "items": {"type": "string"}}
      }
    },
    "regulatory_safety": {
      "type": "object",
      "properties": {
        "certifications_required": {"type": "array", "items": {"type": "string"}},
        "regulatory_bodies": {"type": "array", "items": {"type": "string"}},
        "safety_testing": {"type": "array", "items": {"type": "string"}},
        "compliance_timeline": {"type": "string"}
      }
    }
  },
  "required": ["consumer_use_case", "packaging_formats"]
}
