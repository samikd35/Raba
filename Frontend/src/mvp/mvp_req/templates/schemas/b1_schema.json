{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "amrg_b1_schema",
  "title": "AMRG PRD Schema - B1 Analog Services",
  "description": "Schema for Analog Services Business MVP PRD",
  "allOf": [
    {"$ref": "base_schema.json"}
  ],
  "properties": {
    "template_code": {
      "const": "B1"
    },
    "service_target": {
      "type": "object",
      "required": ["service_offering", "target_segment"],
      "properties": {
        "service_offering": {
          "type": "object",
          "properties": {
            "core_service": {"type": "string"},
            "service_variants": {"type": "array", "items": {"type": "string"}},
            "pricing_approach": {"type": "string"}
          }
        },
        "target_segment": {
          "type": "object",
          "properties": {
            "segment_description": {"type": "string"},
            "geography": {"type": "string"},
            "typical_job_size": {"type": "string"}
          }
        },
        "positioning": {"type": "string"}
      }
    },
    "delivery_workflow": {
      "type": "object",
      "required": ["workflow_steps"],
      "properties": {
        "workflow_steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step_name": {"type": "string"},
              "description": {"type": "string"},
              "responsible_party": {"type": "string"},
              "duration_estimate": {"type": "string"}
            }
          },
          "minItems": 3
        },
        "quality_checkpoints": {"type": "array", "items": {"type": "string"}},
        "client_touchpoints": {"type": "array", "items": {"type": "string"}}
      }
    },
    "job_intake_scheduling": {
      "type": "object",
      "properties": {
        "inquiry_channels": {"type": "array", "items": {"type": "string"}},
        "quoting_process": {"type": "string"},
        "scheduling_method": {"type": "string"},
        "confirmation_process": {"type": "string"}
      }
    },
    "resources_capacity": {
      "type": "object",
      "properties": {
        "key_resources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "resource_type": {"type": "string"},
              "quantity": {"type": "string"},
              "sourcing": {"type": "string"}
            }
          }
        },
        "capacity_constraints": {"type": "array", "items": {"type": "string"}},
        "scaling_approach": {"type": "string"}
      }
    },
    "service_standards": {
      "type": "object",
      "properties": {
        "quality_standards": {"type": "array", "items": {"type": "string"}},
        "turnaround_targets": {"type": "array", "items": {"type": "string"}},
        "guarantee_policy": {"type": "string"},
        "feedback_collection": {"type": "string"}
      }
    }
  },
  "required": ["service_target", "delivery_workflow"]
}
