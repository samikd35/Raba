{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "amrg_c2_schema",
  "title": "AMRG PRD Schema - C2 Hardware/IoT Product",
  "description": "Schema for Hardware/IoT Product MVP PRD",
  "allOf": [
    {"$ref": "base_schema.json"}
  ],
  "properties": {
    "template_code": {
      "const": "C2"
    },
    "sensing_control_job": {
      "type": "object",
      "required": ["core_function", "sensing_capabilities"],
      "properties": {
        "core_function": {"type": "string"},
        "sensing_capabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sensor_type": {"type": "string"},
              "what_measured": {"type": "string"},
              "accuracy_requirement": {"type": "string"}
            }
          }
        },
        "control_capabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "actuator_type": {"type": "string"},
              "action_performed": {"type": "string"}
            }
          }
        },
        "data_outputs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "device_software_interaction": {
      "type": "object",
      "required": ["companion_app"],
      "properties": {
        "companion_app": {
          "type": "object",
          "properties": {
            "platform": {"type": "string", "enum": ["mobile", "web", "desktop", "none"]},
            "key_features": {"type": "array", "items": {"type": "string"}},
            "offline_capability": {"type": "boolean"}
          }
        },
        "cloud_backend": {
          "type": "object",
          "properties": {
            "data_stored": {"type": "array", "items": {"type": "string"}},
            "processing_done": {"type": "array", "items": {"type": "string"}},
            "api_integrations": {"type": "array", "items": {"type": "string"}}
          }
        },
        "firmware_updates": {"type": "string"}
      }
    },
    "connectivity_power": {
      "type": "object",
      "required": ["connectivity_type", "power_source"],
      "properties": {
        "connectivity_type": {
          "type": "string",
          "enum": ["wifi", "cellular", "bluetooth", "lora", "zigbee", "ethernet", "offline"]
        },
        "connectivity_requirements": {"type": "string"},
        "power_source": {
          "type": "string",
          "enum": ["battery", "mains", "solar", "usb", "hybrid"]
        },
        "battery_life_target": {"type": "string"},
        "charging_method": {"type": "string"}
      }
    },
    "deployment_installation": {
      "type": "object",
      "properties": {
        "installation_complexity": {"type": "string", "enum": ["plug_and_play", "simple_setup", "professional_install"]},
        "installation_steps": {"type": "array", "items": {"type": "string"}},
        "environment_requirements": {"type": "array", "items": {"type": "string"}},
        "commissioning_process": {"type": "string"}
      }
    },
    "reliability_compliance": {
      "type": "object",
      "properties": {
        "durability_requirements": {"type": "array", "items": {"type": "string"}},
        "ip_rating": {"type": "string"},
        "certifications_required": {"type": "array", "items": {"type": "string"}},
        "safety_standards": {"type": "array", "items": {"type": "string"}},
        "warranty_policy": {"type": "string"}
      }
    },
    "manufacturing_sourcing": {
      "type": "object",
      "properties": {
        "bom_complexity": {"type": "string", "enum": ["simple", "moderate", "complex"]},
        "key_components": {"type": "array", "items": {"type": "string"}},
        "manufacturing_approach": {"type": "string", "enum": ["in_house", "contract_manufacturing", "hybrid"]},
        "initial_batch_size": {"type": "string"},
        "unit_cost_target": {"type": "string"}
      }
    }
  },
  "required": ["sensing_control_job", "connectivity_power"]
}
